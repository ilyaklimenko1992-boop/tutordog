    {
      "parameters": {
        "jsCode": "const session = $('Выборка вопросов и сборка сессий').first().json;\n\nconst response = await this.helpers.httpRequest({\n  method: 'POST',\n  url: 'https://api.pachca.com/api/shared/v1/messages',\n  headers: {\n    'Authorization': 'Bearer ' + $env.PACHCA_TOKEN + '',\n    'Content-Type': 'application/json'\n  },\n  body: {\n    message: {\n      entity_type: 'user',\n      entity_id: Number(session.pachca_user_id),\n      content: 'Привет! Тебе назначен срез знаний. Нажми кнопку, чтобы начать.',\n      buttons: [[{ text: 'Начать', data: 'start' }]]\n    }\n  }\n});\n\nconst last_message_id = response.data.id;\nreturn [{ json: { ...session, last_message_id } }];"
      },
