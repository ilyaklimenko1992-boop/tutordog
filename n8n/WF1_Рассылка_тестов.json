        "jsCode": "const employee = $input.first().json;\nconst rows = $('Дата теста').all();\nconst settings = rows.find(r => r.json.команда === employee.целевая_аудитория)?.json;\n\nreturn [{ json: {\n  ...employee,\n  цикл: settings.цикл,\n  номер_теста: settings.номер_теста\n} }];"
