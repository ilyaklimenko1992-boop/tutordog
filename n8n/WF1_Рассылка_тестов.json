    {
      "parameters": {
        "jsCode": "const employee = $('Текущий сотрудник').first().json;\nconst value = $input.first().json.propertyName;\n\n// Ключа нет — тест не назначался\nif (!value) {\n  return [{ json: { ...employee, has_session: false } }];\n}\n\nconst normalized = value.replace(/^=/, '');\n\n// Тест завершён — сравниваем session_id\nif (normalized.startsWith('завершён:')) {\n  const completedSessionId = normalized.replace('завершён:', '');\n  const newSessionId = `${employee.employee_id}_${employee.целевая_аудитория}_${employee.цикл}_${employee.номер_теста}_1`;\n  \n  if (completedSessionId === newSessionId) {\n    return [{ json: { ...employee, has_session: true } }];\n  }\n  return [{ json: { ...employee, has_session: false } }];\n}\n\n// Активная сессия\nreturn [{ json: { ...employee, has_session: true } }];"
      },
