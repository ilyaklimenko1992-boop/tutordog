    {
      "parameters": {
        "jsCode": "const schedule = $('Расписание уведомлений').all();\nconst sessions = $('Активные сессии').all()\n  .filter(s => s.json.session_id && s.json.session_id !== '');\n\n// Читаем расписание из таблицы\nconst days = {};\nschedule.forEach(row => {\n  days[row.json.ключ] = Number(row.json.значение);\n});\n\nconst reminder1 = days['reminder_day_1'];      // день 1го напоминания\nconst reminder2 = days['reminder_day_2'];      // день 2го напоминания\nconst reminder3 = days['reminder_day_3'];      // день 3го напоминания\nconst autoClose = days['auto_close_day'];      // дедлайн первой попытки (28 дней)\nconst autoClose2 = days['auto_close_attempt_2_day'] ?? 3; // дедлайн второй попытки (3 дня, по умолчанию)\n\nconst now = new Date();\n\nconst active = sessions\n  .filter(s => ['назначен', 'в процессе'].includes(s.json.статус))\n  .map(s => {\n    const sentAt = new Date(s.json.sent_at);\n    const daysPassed = Math.floor((now - sentAt) / (1000 * 60 * 60 * 24));\n    const reminderCount = Number(s.json.reminder_count || 0);\n    const isAttempt2 = Number(s.json.номер_попытки) === 2;\n\n    // Для второй попытки — короткий дедлайн, для первой — стандартный\n    const дедлайн = isAttempt2 ? autoClose2 : autoClose;\n\n    let action = null;\n\n    // Автозакрытие — одинаково для всех, но с разным дедлайном\n    if (daysPassed >= дедлайн) {\n      action = 'auto_close';\n\n    // Напоминания — только для первой попытки\n    } else if (!isAttempt2) {\n      if (daysPassed >= reminder3 && reminderCount < 3) action = 'reminder_3';\n      else if (daysPassed >= reminder2 && reminderCount < 2) action = 'reminder_2';\n      else if (daysPassed >= reminder1 && reminderCount < 1) action = 'reminder_1';\n    }\n\n    return {\n      ...s.json,\n      days_passed: daysPassed,\n      action: action\n    };\n  })\n  .filter(s => s.action !== null); // убираем тех у кого нет действия\n\nreturn active.map(s => ({ json: s }));"
      },
