      "id": "71e386a2-82a7-40a7-905a-0d3a09efce5f",
      "name": "Ветка reminder_2"
    },
    {
      "parameters": {
        "jsCode": "const sheetData = $('Какое действие?').first().json;\nconst employee = $('Sheets: получить никнейм сотрудника').first().json;\nconst employeeNickname = employee.никнейм_сотрудника;\nconst managerNickname = employee.никнейм_руководителя;\nconst session = { ...sheetData };\n\n// Шаг 1: Отправляем сообщение сотруднику\nconst msgResponse = await this.helpers.httpRequest({\n  method: 'POST',\n  url: 'https://api.pachca.com/api/shared/v1/messages',\n  headers: {\n    'Authorization': 'Bearer ' + $env.PACHCA_TOKEN + '',\n    'Content-Type': 'application/json'\n  },\n  body: {\n    message: {\n      entity_type: 'user',\n      entity_id: Number(session.pachca_user_id),\n      content: `⚠️ Срез знаний не пройден в течение 21 дня. Обрати внимание: через неделю тест закроется автоматически с оценкой 0%.`\n    }\n  }\n});\n\nconst messageId = msgResponse.data.id;\n\n// Шаг 2: Создаём тред под сообщением\nconst threadResponse = await this.helpers.httpRequest({\n  method: 'POST',\n  url: `https://api.pachca.com/api/shared/v1/messages/${messageId}/thread`,\n  headers: {\n    'Authorization': 'Bearer ' + $env.PACHCA_TOKEN + '',\n    'Content-Type': 'application/json'\n  },\n  body: {}\n});\n\nconst threadChatId = threadResponse.data.chat_id;\n\n// Шаг 3: Пишем в тред с упоминанием руководителя\nawait this.helpers.httpRequest({\n  method: 'POST',\n  url: 'https://api.pachca.com/api/shared/v1/messages',\n  headers: {\n    'Authorization': 'Bearer ' + $env.PACHCA_TOKEN + '',\n    'Content-Type': 'application/json'\n  },\n  body: {\n    message: {\n      entity_type: 'chat',\n      entity_id: Number(threadChatId),\n      content: `@${managerNickname} у @${employeeNickname} не пройден срез знаний. Тест закроется автоматически через неделю с оценкой 0%.`\n    }\n  }\n});\n\nreturn [{ json: { session_id: session.session_id, reminder_count: 3 } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1280,
