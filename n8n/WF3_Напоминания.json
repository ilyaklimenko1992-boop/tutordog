      "name": "Ветка reminder_3"
    },
    {
      "parameters": {
        "jsCode": "const session = $input.first().json;\n\n// Сообщение сотруднику\nawait this.helpers.httpRequest({\n  method: 'POST',\n  url: 'https://api.pachca.com/api/shared/v1/messages',\n  headers: {\n    'Authorization': 'Bearer ' + $env.PACHCA_TOKEN + '',\n    'Content-Type': 'application/json'\n  },\n  body: {\n    message: {\n      entity_type: 'user',\n      entity_id: Number(session.pachca_user_id),\n      content: `────────────────\\n✅ Тест завершён\\n\\n🔴 **0%**\\n\\n────────────────\\nТест закрыт автоматически в связи с истечением срока прохождения.`\n    }\n  }\n});\n\nreturn [{ json: { \n  session_id: session.session_id,\n  employee_id: session.employee_id,\n  pachca_user_id: session.pachca_user_id,\n  цикл: session.цикл,\n  номер_теста: session.номер_теста,\n  номер_попытки: session.номер_попытки,\n  ФИО: session.ФИО,\n  целевая_аудитория: session.целевая_аудитория,\n  reminder_count: session.reminder_count\n} }];"
      },
