      "parameters": {
        "jsCode": "const employee = $('Данные сотрудника').first().json;\nconst row = $('Текущая строка').first().json;\nconst value = $input.first().json.propertyName ?? '';\n\n// Активная сессия — пропускаем\nif (value && !value.startsWith('завершён:')) {\n  return [{ json: { \n    blocked: true,\n    employee_id: row.employee_id,\n    причина: 'Есть активная сессия: ' + value\n  } }];\n}\n\n// Можно открывать вторую попытку\nreturn [{ json: {\n  blocked: false,\n  employee_id: employee.employee_id,\n  ФИО: employee.ФИО,\n  pachca_user_id: Number(employee.pachca_user_id),\n  целевая_аудитория: employee.целевая_аудитория,\n  никнейм: employee.никнейм_сотрудника,\n  никнейм_руководителя: employee.никнейм_руководителя,\n  цикл: row.цикл,\n  номер_теста: row.номер_теста,\n  attempt_id: $('Текущая строка').first().json.attempt_id,\n  row_number: row.row_number\n} }];"
