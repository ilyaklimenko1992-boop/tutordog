    {
      "parameters": {
        "jsCode": "const allQuestions = $input.all();\nconst employee = $('Проверка активной сессии').first().json;\n\n\nconst filtered = allQuestions.filter(q => {\n  const roles = q.json.целевая_аудитория ? q.json.целевая_аудитория.split(',').map(r => r.trim()) : [];\n  const активен = q.json.активен !== 'нет';\n  const активенС = q.json.активен_с\n    ? new Date(q.json.активен_с.split('.').reverse().join('-')) <= new Date()\n    : true;\n  return roles.includes(employee.целевая_аудитория) && активен && активенС;\n});\n\nif (filtered.length < 10) {\n  return [{ json: { skip: true, employee_id: employee.employee_id } }];\n}\n\nconst shuffled = filtered.sort(() => Math.random() - 0.5);\nconst selected = shuffled.slice(0, 10);\nconst questionIds = selected.map(q => q.json.question_id).join(',');\n\nconst questionsData = {};\nselected.forEach(q => {\n  questionsData[q.json.question_id] = {\n    текст_вопроса: q.json.текст_вопроса,\n    вариант_A: q.json.вариант_A,\n    вариант_B: q.json.вариант_B,\n    вариант_C: q.json.вариант_C,\n    вариант_D: q.json.вариант_D,\n    правильный_ответ: q.json.правильный_ответ,\n    вес_баллов: q.json.вес_баллов,\n    инструкция_БЗ: q.json.инструкция_БЗ\n  };\n});\n\nconst sessionId = `${employee.employee_id}_${employee.целевая_аудитория}_${employee.цикл}_${employee.номер_теста}_2`;\n\nconst session = {\n  session_id: sessionId,\n  employee_id: employee.employee_id,\n  pachca_user_id: Number(employee.pachca_user_id),\n  ФИО: employee.ФИО,\n  целевая_аудитория: employee.целевая_аудитория,\n  цикл: employee.цикл,\n  номер_теста: employee.номер_теста,\n  номер_попытки: 2,\n  attempt_id: $('Проверка активной сессии').first().json.attempt_id,\n  никнейм: employee.никнейм,\n  никнейм_руководителя: employee.никнейм_руководителя,\n  question_ids: questionIds,\n  questions_data: JSON.stringify(questionsData),\n  current_question_index: 0,\n  total_questions: 10,\n  answers: '{}',\n  sent_at: new Date().toISOString(),\n  reminder_count: 0,\n  total_score: 0,\n  max_score: 0,\n  статус: 'назначен',\n  row_number: employee.row_number\n};\n\nreturn [{ json: session }];"
      },
